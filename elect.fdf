SystemName    elec                                                                                                                     
SystemLabel   elec

NumberOfAtoms        16
NumberOfSpecies      1

%block ChemicalSpeciesLabel
    1  6 C
%endblock ChemicalSpeciesLabel 
NumberOfAtoms    16

NumberOfSpecies  1
%block ChemicalSpeciesLabel
    1    6  C
%endblock ChemicalSpeciesLabel

LatticeConstant 1.0 Ang
%block LatticeVectors
  20.7202700000    0.0000000000    0.0000000000
   0.0000000000   21.6271870000    0.0000000000
   0.0000000000    0.0000000000   4.609835
%endblock LatticeVectors

AtomicCoordinatesFormat NotScaledCartesianAng
%block AtomicCoordinatesAndAtomicSpecies
3.412262	0.813594	0.814558	1
0.813668	0.813594	0.814558	1
8.608377	0.813594	0.814558	1
